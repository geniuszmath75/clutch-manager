{
  "compilerOptions": {
    "target": "ES2017",
    "module": "None",
    "lib": ["ES2017", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "outDir": "public/assets/js",
    "rootDir": "public/assets/ts",
    "removeComments": false,
    "sourceMap": true
  },
  "include": ["public/assets/ts/**/*.ts"],
  "exclude": ["node_modules"]
}